# OCR + Translation API Environment Variables

# Python
PYTHONUNBUFFERED=1
DEBUG=false

# OCR Model Path
EASYOCR_MODULE_PATH=/root/.EasyOCR

# Whisper (Speech-to-Text) Configuration
# Model size: tiny, base, small, medium, large-v3
WHISPER_MODEL=base

# Device: cpu or cuda (GPU)
WHISPER_DEVICE=cpu

# Compute type: int8, int16, float16, float32
WHISPER_COMPUTE_TYPE=int8

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Deployment (auto-set by Railway)
# PORT=8000  # Railway sets this automatically
